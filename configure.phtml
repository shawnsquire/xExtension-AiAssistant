<script>
document.getElementById('test-api-key').addEventListener('click', function() {
	var btn = this;
	var result = document.getElementById('api-key-result');
	var apiKey = document.getElementById('api_key').value;
	btn.disabled = true;
	result.textContent = 'Testing...';
	result.style.color = '';

	var url = new URL(window.location.pathname, window.location.origin);
	url.searchParams.set('c', 'extension');
	url.searchParams.set('a', 'configure');
	url.searchParams.set('e', 'AI Assistant');
	url.searchParams.set('ajax_action', 'test_api_key');

	fetch(url.toString(), {
		method: 'POST',
		headers: { 'Content-Type': 'application/json; charset=UTF-8' },
		body: JSON.stringify({
			api_key: apiKey,
			ajax: true,
			_csrf: context.csrf
		})
	})
	.then(function(r) { return r.json(); })
	.then(function(data) {
		result.textContent = data.message;
		result.style.color = data.status === 'ok' ? '#22c55e' : '#ef4444';
	})
	.catch(function() {
		result.textContent = 'Request failed';
		result.style.color = '#ef4444';
	})
	.finally(function() {
		btn.disabled = false;
	});
});
</script>
